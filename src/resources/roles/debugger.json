  "tools": [
    "Debuggers (GDB, Chrome DevTools, etc.)",
    "Profilers (perf, Valgrind, etc.)",
    "Log aggregators (ELK, Splunk)",
    "APM tools (New Relic, DataDog)",
    "Memory analyzers"
