      "architect": "Si el problema requiere cambios de diseño"
    }
  },
  "checklist": {
    "entry": [
      "¿Se puede reproducir el error?",
      "¿Están disponibles los logs?",
      "¿Se tiene acceso al entorno afectado?",
      "¿Está claro el comportamiento esperado?"
    ],
    "execution": [
      "Reproducir el error localmente",
      "Recolectar toda la información relevante",
      "Analizar logs y stack traces",
      "Formular y probar hipótesis",
      "Identificar causa raíz",
      "Implementar y probar solución",
      "Crear test de regresión"
    ],
    "exit": [
      "¿El error está completamente resuelto?",
      "¿Se identificó la causa raíz?",
      "¿Existe test para prevenir regresión?",
      "¿Está documentada la solución?",
      "¿Se actualizó la documentación?"
    ]
