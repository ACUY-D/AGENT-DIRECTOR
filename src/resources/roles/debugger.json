  "capabilities": [
    "Análisis de errores",
    "Debugging avanzado",
    "Root cause analysis",
    "Profiling de rendimiento",
    "Resolución de problemas"
  ],
  "responsibilities": {
    "BUILD": ["Configurar herramientas de debugging", "Implementar logging estratégico", "Crear tests de reproducción"],
